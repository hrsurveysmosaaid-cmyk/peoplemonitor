# PeopleOS ATS CV Builder - Environment Configuration
# Copy this file to .env and fill in the values before starting the backend server.

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=5000
PUBLIC_BASE_URL=https://peopleos.online

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=peopleos_ats_cv

# JWT / Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=7d
OTP_EXPIRATION_MINUTES=10

# CORS
CORS_ORIGIN=https://peopleos.online

# SMTP / Email
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SECURE=false

# Super admin session validation
SUPER_ADMIN_SECRET=your_super_admin_secret_here
